{
  "name": "dao-simulator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 7884",
    "build": "node scripts/build.js",
    "build:next": "next build --turbopack",
    "bundle:browser": "tsx scripts/bundle-browser-data.ts",
    "start": "node scripts/start.js",
    "start:next": "next start",
    "server": "npx tsx server.ts",
    "server:build": "tsc -p tsconfig.server.json",
    "server:start": "node dist/server.js",
    "lint": "eslint",
    "test": "npm run test:unit",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "node scripts/test-e2e.js",
    "test:e2e:ui": "node scripts/test-e2e.js --ui",
    "test:e2e:headed": "node scripts/test-e2e.js --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "node scripts/test-e2e.js --project=smoke",
    "test:e2e:dashboard": "node scripts/test-e2e.js --project=dashboard",
    "test:e2e:simulation": "node scripts/test-e2e.js --project=simulation",
    "test:e2e:a11y": "node scripts/test-e2e.js --project=accessibility",
    "test:e2e:visualizations": "node scripts/test-e2e.js --project=visualizations",
    "test:e2e:simulate": "node scripts/test-e2e.js --project=simulate",
    "test:e2e:mobile": "node scripts/test-e2e.js --project=mobile",
    "test:e2e:raw": "playwright test",
    "test:all": "npm run test:unit && npm run test:e2e",
    "examples": "tsx examples/run-scenarios.ts",
    "experiment": "tsx scripts/run-experiment.ts",
    "exp": "tsx scripts/experiment-manager.ts",
    "validate": "tsx scripts/run-validation.ts",
    "generate-baselines": "tsx scripts/generate-baselines.ts",
    "paper:update": "tsx scripts/paper-update.ts",
    "paper:update:p1": "tsx scripts/paper-update.ts --paper-dir paper_p1 --profile p1",
    "paper:update:p2": "tsx scripts/paper-update.ts --paper-dir paper_p2 --profile p2",
    "paper:update:llm": "tsx scripts/paper-update.ts --paper-dir paper_llm --profile llm",
    "paper:charts": "tsx scripts/paper-update.ts --charts-only",
    "paper:archive": "tsx scripts/paper-archive.ts --profile full",
    "paper:archive:all": "tsx scripts/paper-archive.ts --profile all",
    "paper:archive:list": "tsx scripts/paper-archive.ts --list",
    "paper:compile": "tsx scripts/paper-compile.ts --archive",
    "paper:compile:p1": "tsx scripts/paper-compile.ts --profile p1 --archive",
    "paper:compile:p2": "tsx scripts/paper-compile.ts --profile p2 --archive",
    "paper:compile:llm": "tsx scripts/paper-compile.ts --profile llm --archive",
    "paper:compile:all": "tsx scripts/paper-compile.ts --profile all --archive",
    "paper:compile:quick": "tsx scripts/paper-compile.ts",
    "paper:full": "npm run paper:update && npm run paper:compile",
    "paper:summary": "tsx scripts/generate-executive-summary.ts",
    "paper:suite": "tsx scripts/run-paper-suite.ts all",
    "paper:suite:p1": "tsx scripts/run-paper-suite.ts all --profile p1",
    "paper:suite:p2": "tsx scripts/run-paper-suite.ts all --profile p2",
    "paper:suite:llm": "tsx scripts/run-paper-suite.ts all --profile llm",
    "paper:plain-english": "tsx scripts/regenerate-plain-english-papers.ts",
    "paper:consolidate": "tsx scripts/consolidate-paper-assets.ts",
    "paper:cleanup": "tsx scripts/cleanup-paper-temp.ts",
    "paper:pack": "tsx scripts/run-paper-suite.ts pack",
    "paper:build:p1": "npm run paper:suite:p1 && npm run paper:update:p1 -- --compile",
    "paper:build:p2": "npm run paper:suite:p2 && npm run paper:update:p2 -- --compile",
    "paper:build:llm": "npm run paper:suite:llm && npm run paper:update:llm -- --compile",
    "paper:build:both": "npm run paper:suite && npm run paper:update:p1 -- --compile && npm run paper:update:p2 -- --compile",
    "paper:build:all": "npm run paper:build:both && npm run paper:build:llm && npm run paper:pack"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.3.0",
    "@types/three": "^0.180.0",
    "ioredis": "^5.8.0",
    "next": "^16.0.10",
    "next-auth": "^5.0.0-beta.30",
    "postprocessing": "^6.37.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.2.1",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "three": "^0.180.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.8",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.8"
  }
}
