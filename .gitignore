# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# typescript
*.tsbuildinfo
next-env.d.ts

# experiment results
/results/
!/results/historical/
/results/historical/*
!/results/historical/calibration/

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# logs
*.log
*.err
dev.log
dev.err
server.log
server.err
playwright-*.log
playwright-*.err

# temp files
tmpclaude-*
debug-*.ts
output.txt
nul

# LaTeX tools
tools/
paper/*.pdf
paper/*.aux
paper/*.log
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.toc

# Paper generated files (temp)
paper/generated/

# Track archived paper versions as zips
!paper/archive/*.zip

# Simulation checkpoints
.checkpoints/

# Python cache
__pycache__/
*.pyc

# Claude local settings
.claude/settings.local.json

