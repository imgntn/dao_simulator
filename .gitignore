# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# typescript
*.tsbuildinfo
next-env.d.ts

# experiment results (archived to R2: dao-research-media bucket)
/results/
!/results/historical/
/results/historical/*
!/results/historical/calibration/

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# logs
*.log
*.err

# temp files
tmpclaude-*
debug-*.ts
output.txt
nul

# PDFs (generated artifacts — upload to R2, not tracked)
*.pdf

# LaTeX build artifacts
tools/
*.aux
*.bbl
*.blg
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz

# Paper generated files (temp)
paper/generated/

# Simulation checkpoints
.checkpoints/

# Python cache
__pycache__/
*.pyc

# Claude local settings
.claude/settings.local.json

# Docs (drafts / transcripts)
docs/

# Podcast media (hosted on Cloudflare R2)
podcast_media/

# Wrangler local state
.wrangler/

# Archived directories (backed up to R2: dao-research-media bucket)
/archive/
/legacy-python/
/paper_p1/
/paper_p2/
/paper_llm/
