{
  "_meta": {
    "name": "DAO Paper Chart Stylizer",
    "description": "Enhances matplotlib charts with artistic styling for paper figures",
    "author": "DAO Simulator",
    "version": "1.0"
  },
  "nodes": {
    "1": {
      "class_type": "LoadImage",
      "inputs": {},
      "_meta": {
        "title": "Load Chart Image",
        "note": "Load the matplotlib-generated chart"
      }
    },
    "2": {
      "class_type": "ImageScale",
      "inputs": {
        "image": ["1", 0],
        "upscale_method": "lanczos",
        "width": 2400,
        "height": 1500,
        "crop": "disabled"
      },
      "_meta": {
        "title": "Upscale for Quality"
      }
    },
    "3": {
      "class_type": "VAEEncode",
      "inputs": {
        "pixels": ["2", 0],
        "vae": ["4", 0]
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "sd_xl_base_1.0.safetensors"
      },
      "_meta": {
        "title": "Load SDXL Model",
        "note": "Use SDXL for high-quality enhancement"
      }
    },
    "5": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "professional academic chart, clean lines, scientific visualization, publication quality, white background, clear labels, high contrast, vector graphics style",
        "clip": ["4", 1]
      },
      "_meta": {
        "title": "Positive Prompt"
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "blurry, distorted text, artifacts, noise, low quality, pixelated, watermark",
        "clip": ["4", 1]
      },
      "_meta": {
        "title": "Negative Prompt"
      }
    },
    "7": {
      "class_type": "KSampler",
      "inputs": {
        "model": ["4", 0],
        "positive": ["5", 0],
        "negative": ["6", 0],
        "latent_image": ["3", 0],
        "seed": 42,
        "steps": 20,
        "cfg": 7.0,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 0.3
      },
      "_meta": {
        "title": "Denoise/Enhance",
        "note": "Low denoise to preserve chart accuracy"
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["7", 0],
        "vae": ["4", 2]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "images": ["8", 0],
        "filename_prefix": "paper_chart"
      },
      "_meta": {
        "title": "Save Enhanced Chart"
      }
    }
  },
  "workflow_api_format": {
    "note": "This workflow enhances matplotlib charts while preserving data accuracy",
    "usage": [
      "1. Generate base chart with paper-update.ts",
      "2. Load chart image in node 1",
      "3. Run workflow",
      "4. Output saved with 'paper_chart' prefix"
    ]
  }
}
