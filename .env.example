# API Authentication
# Production: use at least 24 random characters.
API_KEY=your-secret-api-key-here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:7884
# Production: use at least 32 random characters.
NEXTAUTH_SECRET=generate-a-secret-key-here

# Admin Credentials (for demo/dev only)
ADMIN_USERNAME=admin
# Production: use at least 12 random characters and do not keep this placeholder.
ADMIN_PASSWORD=changeme

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379
USE_REDIS=false
# Production: Redis-backed rate limits are enabled automatically when REDIS_URL is set.
# Set USE_REDIS_RATE_LIMITS=false only for single-instance deployments or debugging.
USE_REDIS_RATE_LIMITS=true

# Environment
NODE_ENV=development

# Analytics (PostgreSQL — optional, analytics disabled if not set)
DATABASE_URL=

# Analytics Email Report (Zoho SMTP — optional)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# REPORT_RECIPIENTS=hello@daosimulator.com,james@jamesbpollack.com,hello@playablefuture.com

TALLY_API_KEY=your-tally-api-key-here

# Premium podcast player embed (set to deployed URL for 3D avatar experience)
NEXT_PUBLIC_PODCAST_EMBED_URL=
